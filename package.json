{
  "name": "ctf-pilot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "build:server:exe": "esbuild server.ts --bundle --platform=node --format=cjs --external:vite --outfile=build/server.cjs",
    "copy:dist:exe": "powershell -NoProfile -Command \"New-Item -ItemType Directory -Force -Path release/dist | Out-Null; Copy-Item -Recurse -Force dist/* release/dist/\"",
    "pack:exe": "npm run build && npm run build:server:exe && pkg build/server.cjs --targets node18-win-x64 --output release/CTF Pilot.exe && npm run copy:dist:exe"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.13",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.9",
    "pkg": "^5.8.1",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
